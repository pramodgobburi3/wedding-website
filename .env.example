# Copy to .env.local and fill in values

# Google Apps Script — RSVP form submission
VITE_APPS_SCRIPT_URL=https://script.google.com/macros/s/YOUR_DEPLOYMENT_ID/exec

# Cloudinary — gallery images
# 1. Create a free account at cloudinary.com
# 2. Find your Cloud Name in the dashboard
# 3. Go to Settings > Security > uncheck "Resource list" to enable the list API
# 4. Upload photos and tag them all with the tag below (e.g. "wedding-gallery")
VITE_CLOUDINARY_CLOUD_NAME=your_cloud_name
VITE_CLOUDINARY_TAG=wedding-gallery

# Set this to your repo name when deploying to GitHub Pages (e.g. /wedding-website)
# Leave as / if using a custom domain
VITE_BASE_URL=/
